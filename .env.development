# Loaded by `next dev` only — never by `next build` / production.
# This is the per-project debug switch for the OASIS SDK: it makes the
# client log every request/response/error and attach the backend's verbose
# exception chain (when the API runs with OASIS:DebugErrors) to SdkError.
# Because Next.js never loads .env.development in a production build, a
# production deployment can never turn this on.
NEXT_PUBLIC_OASIS_DEBUG=true
